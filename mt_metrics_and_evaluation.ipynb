   "source": [
    "from __future__ import annotations\n",
    "\n",
    "import json\n",
    "import re\n",
    "from pathlib import Path\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from IPython.display import display\n",
    "from scipy.stats import kendalltau, spearmanr\n",
    "from sacrebleu.metrics import BLEU, CHRF\n",
    "\n",
    "LANGUAGE_PAIR = \"en-de\"\n",
    "CSV_PATH = Path(\"wmt_mqm_2023_scored.csv\")\n",
    "OUT_PATH = Path(\"wmt_mqm_2023_with_auto_metrics.csv\")\n",
    "ERROR_ANALYSIS_PATH = Path(\"error_analysis_dev_seed6761.csv\")\n",
    "\n",
    "RANDOM_STATE = 6761\n",
    "DEV_FRAC = 0.8\n",
    "STRESS_QUANTILE = 0.75\n",
    "STRESS_SOURCE_COL = \"stress_mvp\"\n",
    "\n",
    "COMET_MODEL = \"Unbabel/wmt22-comet-da\"\n",
    "COMET_BATCH = 4\n",
    "\n",
    "RUN_COMET = True\n",
    "N_BASELINE_RANDOM = 500\n",
    "\n",
    "TAG_RE = re.compile(r\"</?v>\")\n",
    "\n",
    "# numbers / money / dates in english source (simple regex)\n",
    "NUMBER_PATTERN = re.compile(\n",
    "    r\"(?i)\\b\\d{1,3}(?:,\\d{3})*(?:\\.\\d+)?\\b|\"\n",
    "    r\"\\b\\d+(?:\\.\\d+)?%|\"\n",
    "    r\"\\$\\s*\\d+|\"\n",
    "    r\"\\b\\d{1,2}[/\\-]\\d{1,2}[/\\-]\\d{2,4}\\b|\"\n",
    "    r\"\\b\\d+\\s*(?:USD|EUR|GBP|dollars?|euros?)\\b\"\n",
    ")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 24,
   "id": "helpers",
   "metadata": {},
   "outputs": [],
   "source": [
    "def strip_mqm_tags(text: str) -> str:\n",
    "    return TAG_RE.sub(\"\", text or \"\")\n",
    "\n",
    "\n",
    "def count_regex_numeric_signals(text: str) -> int:\n",
    "    if not isinstance(text, str) or not text:\n",
    "        return 0\n",
    "    return len(NUMBER_PATTERN.findall(text))\n",
    "\n",
    "\n",
    "def parse_metadata(meta: str) -> dict:\n",
    "    if not isinstance(meta, str) or not meta.strip():\n",
    "        return {}\n",
    "    try:\n",
    "        return json.loads(meta)\n",
    "    except json.JSONDecodeError:\n",
    "        return {}\n",
    "\n",
    "\n",
    "def meta_mqm(meta: dict) -> float:\n",
    "    try:\n",
    "        return float(meta[\"segment\"][\"metrics\"][\"MQM\"])\n",
    "    except (KeyError, TypeError, ValueError):\n",
    "        return float(\"nan\")\n",
    "\n",
    "\n",
    "def meta_reference(meta: dict) -> str:\n",
    "    try:\n",
    "        refs = meta[\"segment\"][\"references\"]\n",
    "        return refs.get(\"Reference\") or \"\"\n",
    "    except (KeyError, TypeError):\n",
    "        return \"\""
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 25,
   "id": "load",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "MVP data: pair=en-de rows=3121 segments=90 systems=13 split=80% dev / 20% test (by segment)\n",
      "reference_ok 3121 mqm_ok 1166\n",
      "stress_mvp describe: count    3121.000000\n",
      "mean        1.210830\n",
      "std         1.414131\n",
      "min         0.000000\n",
      "25%         0.000000\n",
      "50%         1.000000\n",
      "75%         2.000000\n",
      "max         6.000000\n"
     ]
    }
   ],
   "source": [
    "df = pd.read_csv(CSV_PATH)\n",
    "doc_cols = [c for c in df.columns if \"Documentation\" in c or \"MAROT\" in c]\n",
    "if doc_cols:\n",
    "    df = df.drop(columns=doc_cols)\n",
    "\n",
    "parsed = df[\"metadata\"].map(parse_metadata)\n",
    "df[\"mqm\"] = [meta_mqm(m) for m in parsed]\n",
    "df[\"reference_raw\"] = [meta_reference(m) for m in parsed]\n",
    "\n",
    "df[\"seg_key\"] = df[\"doc\"].astype(str) + \"::\" + df[\"globalSegId\"].astype(str)\n",
    "seg_ref = df.groupby(\"seg_key\")[\"reference_raw\"].apply(\n",
    "    lambda s: next((x for x in s if isinstance(x, str) and x.strip()), \"\")\n",
    ")\n",
    "df[\"reference\"] = df[\"seg_key\"].map(seg_ref)\n",
    "df[\"mt\"] = df[\"target\"].map(strip_mqm_tags)\n",
    "df[\"human_score\"] = -df[\"mqm\"]\n",
    "\n",
    "df[\"number_regex_hits\"] = df[\"source\"].map(count_regex_numeric_signals)\n",
    "ec = (\n",
    "    df[\"entity_count\"].fillna(0).astype(int)\n",
    "    if \"entity_count\" in df.columns\n",
    "    else pd.Series(0, index=df.index, dtype=int)\n",
    ")\n",
    "df[\"stress_mvp\"] = ec + df[\"number_regex_hits\"]\n",
    "\n",
    "print(LANGUAGE_PAIR, len(df), \"rows,\", df[\"seg_key\"].nunique(), \"segments,\", df[\"system\"].nunique(), \"systems\")\n",
    "print(\"dev/test:\", f\"{DEV_FRAC:.0%}\", \"/\", f\"{1-DEV_FRAC:.0%}\")\n",
    "print(\"ref ok:\", int((df[\"reference\"].astype(str).str.len() > 0).sum()), \"mqm ok:\", int(df[\"mqm\"].notna().sum()))\n",
    "print(df[\"stress_mvp\"].describe())\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 26,
   "id": "split",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "dev_segments=72 test_segments=18 stress_col=stress_mvp threshold>=1.0000 (q=0.75 on dev)\n"
     ]
    }
   ],
   "source": [
    "rng = np.random.default_rng(RANDOM_STATE)\n",
    "seg_keys = np.asarray(df[\"seg_key\"].unique().tolist(), dtype=object)\n",
    "rng.shuffle(seg_keys)\n",
    "cut = int(len(seg_keys) * DEV_FRAC)\n",
    "dev_segs = set(seg_keys[:cut])\n",
    "test_segs = set(seg_keys[cut:])\n",
    "df[\"split\"] = df[\"seg_key\"].map(lambda k: \"dev\" if k in dev_segs else \"test\")\n",
    "\n",
    "stress_by_seg = df.groupby(\"seg_key\")[STRESS_SOURCE_COL].max()\n",
    "dev_stress_vals = stress_by_seg[stress_by_seg.index.isin(dev_segs)]\n",
    "stress_threshold = float(np.quantile(dev_stress_vals, STRESS_QUANTILE))\n",
    "df[\"stress_slice\"] = df[STRESS_SOURCE_COL] >= stress_threshold\n",
    "\n",
    "print(\"dev segs\", len(dev_segs), \"test segs\", len(test_segs), \"stress cutoff\", round(stress_threshold, 4), \"q=\", STRESS_QUANTILE, \"(from dev)\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 27,
   "id": "bleu",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "BLEU/chrF done\n"
     ]
    }
   ],
   "source": [
    "bleu_metric = BLEU(effective_order=True)\n",
    "chrf_metric = CHRF()\n",
    "\n",
    "\n",
    "def sentence_bleu(hyp: str, ref: str) -> float:\n",
    "    return float(bleu_metric.sentence_score(hyp, [ref]).score)\n",
    "\n",
    "\n",
    "def sentence_chrf(hyp: str, ref: str) -> float:\n",
    "    return float(chrf_metric.sentence_score(hyp, [ref]).score)\n",
    "\n",
    "\n",
    "bleus, chrfs = [], []\n",
    "for hyp, ref in zip(df[\"mt\"], df[\"reference\"]):\n",
    "    r = ref if isinstance(ref, str) else \"\"\n",
    "    if not r.strip():\n",
    "        bleus.append(np.nan)\n",
    "        chrfs.append(np.nan)\n",
    "        continue\n",
    "    bleus.append(sentence_bleu(hyp, r))\n",
    "    chrfs.append(sentence_chrf(hyp, r))\n",
    "\n",
    "df[\"bleu\"] = bleus\n",
    "df[\"chrf\"] = chrfs\n",
    "print(\"bleu chrf done\")\n"
   ]
  },
