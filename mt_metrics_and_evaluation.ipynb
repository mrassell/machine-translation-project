   "source": [
    "# disagreement flags for later error analysis (proposal: high auto score + bad human, etc.)\n",
    "# uses 25% / 75% quantiles on the whole dataframe for each metric (simple and stable)\n",
    "\n",
    "\n",
    "def add_hi_lo_flags(metric_col: str, hi_col: str, lo_col: str) -> None:\n",
    "    s = df[metric_col].dropna()\n",
    "    if len(s) < 20:\n",
    "        df[hi_col] = False\n",
    "        df[lo_col] = False\n",
    "        return\n",
    "    hi = s.quantile(0.75)\n",
    "    lo = s.quantile(0.25)\n",
    "    df[hi_col] = (df[metric_col] >= hi) & (df[\"mqm\"] > 0)\n",
    "    df[lo_col] = (df[metric_col] <= lo) & (df[\"mqm\"] == 0)\n",
    "\n",
    "\n",
    "add_hi_lo_flags(\"comet\", \"err_high_comet_bad_mqm\", \"err_low_comet_good_mqm\")\n",
    "add_hi_lo_flags(\"bleu\", \"err_high_bleu_bad_mqm\", \"err_low_bleu_good_mqm\")\n",
    "add_hi_lo_flags(\"chrf\", \"err_high_chrf_bad_mqm\", \"err_low_chrf_good_mqm\")\n",
    "\n",
    "print(\n",
    "    \"comet hi/bad\", int(df[\"err_high_comet_bad_mqm\"].sum()),\n",
    "    \"comet lo/good\", int(df[\"err_low_comet_good_mqm\"].sum()),\n",
    ")\n",
    "print(\n",
    "    \"bleu hi/bad\", int(df[\"err_high_bleu_bad_mqm\"].sum()),\n",
    "    \"bleu lo/good\", int(df[\"err_low_bleu_good_mqm\"].sum()),\n",
    ")\n",
    "print(\n",
    "    \"chrf hi/bad\", int(df[\"err_high_chrf_bad_mqm\"].sum()),\n",
    "    \"chrf lo/good\", int(df[\"err_low_chrf_good_mqm\"].sum()),\n",
    ")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "corrdefs",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Active metrics: ['bleu', 'chrf', 'comet']\n"
     ]
    }
   ],
   "source": [
    "METRICS = [\"bleu\", \"chrf\"]\n",
    "if RUN_COMET and df[\"comet\"].notna().any():\n",
    "    METRICS.append(\"comet\")\n",
    "\n",
    "\n",
    "def corr_table(frame: pd.DataFrame, metrics: list[str], human_col: str = \"human_score\") -> pd.DataFrame:\n",
    "    rows_out = []\n",
    "    mask = frame[human_col].notna()\n",
    "    for m in metrics:\n",
    "        mmask = mask & frame[m].notna()\n",
    "        x, y = frame.loc[mmask, m].to_numpy(), frame.loc[mmask, human_col].to_numpy()\n",
    "        if len(x) < 3:\n",
    "            rows_out.append(\n",
    "                {\n",
    "                    \"metric\": m,\n",
    "                    \"n\": len(x),\n",
    "                    \"spearman_r\": np.nan,\n",
    "                    \"spearman_p\": np.nan,\n",
    "                    \"kendall_tau\": np.nan,\n",
    "                    \"kendall_p\": np.nan,\n",
    "                }\n",
    "            )\n",
    "            continue\n",
    "        sp = spearmanr(x, y)\n",
    "        kd = kendalltau(x, y)\n",
    "        rows_out.append(\n",
    "            {\n",
    "                \"metric\": m,\n",
    "                \"n\": len(x),\n",
    "                \"spearman_r\": float(sp.statistic),\n",
    "                \"spearman_p\": float(sp.pvalue),\n",
    "                \"kendall_tau\": float(kd.statistic),\n",
    "                \"kendall_p\": float(kd.pvalue),\n",
    "            }\n",
    "        )\n",
    "    return pd.DataFrame(rows_out)\n",
    "\n",
    "\n",
    "def metric_metric_spearman(frame: pd.DataFrame, metrics: list[str]) -> pd.DataFrame:\n",
    "    out = []\n",
    "    mask = frame[metrics].notna().all(axis=1)\n",
    "    if mask.sum() < 3:\n",
    "        return pd.DataFrame(out)\n",
    "    sub = frame.loc[mask, metrics]\n",
    "    for i, a in enumerate(metrics):\n",
    "        for b in metrics[i + 1 :]:\n",
    "            sp = spearmanr(sub[a], sub[b])\n",
    "            out.append({\"m1\": a, \"m2\": b, \"spearman_r\": float(sp.statistic), \"n\": int(mask.sum())})\n",
    "    return pd.DataFrame(out)\n",
    "\n",
    "\n",
    "def report_slice(name: str, frame: pd.DataFrame) -> None:\n",
    "    print(\"\\n===\", name, \"n=\", len(frame), \"===\")\n",
    "    display(corr_table(frame, METRICS))\n",
    "    mm = metric_metric_spearman(frame, METRICS)\n",
    "    if len(mm):\n",
    "        display(mm)\n",
    "\n",
    "\n",
    "def slice_frame(split: str | None, stress: bool | None) -> pd.DataFrame:\n",
    "    out = df\n",
    "    if split is not None:\n",
    "        out = out[out[\"split\"] == split]\n",
    "    if stress is True:\n",
    "        out = out[out[\"stress_slice\"]]\n",
    "    elif stress is False:\n",
    "        out = out[~out[\"stress_slice\"]]\n",
    "    return out\n",
    "\n",
    "\n",
    "print(\"metrics:\", METRICS)\n"
   ]
  },
