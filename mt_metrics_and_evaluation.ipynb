    "def load_comet():\n",
    "    import importlib.util\n",
    "    import subprocess\n",
    "    import sys\n",
    "\n",
    "    import torch\n",
    "\n",
    "    if importlib.util.find_spec(\"comet\") is None:\n",
    "        print(\"pip installing comet, wait...\")\n",
    "        subprocess.check_call(\n",
    "            [sys.executable, \"-m\", \"pip\", \"install\", \"-q\", \"torch\", \"unbabel-comet\"]\n",
    "        )\n",
    "    from comet import download_model, load_from_checkpoint\n",
    "\n",
    "    if hasattr(torch.backends, \"mps\"):\n",
    "        torch.backends.mps.is_available = lambda: False  # noqa: E731\n",
    "\n",
    "    ckpt = download_model(COMET_MODEL)\n",
    "    return load_from_checkpoint(ckpt)\n",
    "\n",
    "\n",
    "def comet_predict(model, batch: list[dict]) -> list[float]:\n",
    "    out = model.predict(batch, batch_size=COMET_BATCH, gpus=0)\n",
    "    if isinstance(out, dict) and \"scores\" in out:\n",
    "        scores = out[\"scores\"]\n",
    "    else:\n",
    "        scores = out\n",
    "    return [float(x) for x in np.asarray(scores).reshape(-1)]\n",
    "\n",
    "\n",
    "if RUN_COMET:\n",
    "    model = load_comet()\n",
    "    rows = [{\"src\": s or \"\", \"mt\": h or \"\", \"ref\": r or \"\"} for s, h, r in zip(df[\"source\"], df[\"mt\"], df[\"reference\"])]\n",
    "    df[\"comet\"] = comet_predict(model, rows)\n",
    "    print(\"comet done\")\n",
    "else:\n",
    "    df[\"comet\"] = np.nan\n",
    "    print(\"skipped comet\")\n"
   ]
  },
