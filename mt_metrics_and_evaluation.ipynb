    "    base_cols.append(\"entity_count\")\n",
    "cols = [c for c in base_cols + err_cols if c in df.columns]\n",
    "\n",
    "ea = df.loc[df[\"split\"] == \"dev\", cols].copy()\n",
    "ea.to_csv(ERROR_ANALYSIS_PATH, index=False)\n",
    "\n",
    "summary = {\n",
    "    \"random_seed\": RANDOM_STATE,\n",
    "    \"stress_quantile_on_dev\": STRESS_QUANTILE,\n",
    "    \"stress_threshold_value\": float(stress_threshold),\n",
