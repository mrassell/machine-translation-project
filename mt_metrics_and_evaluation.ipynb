   "source": [
    "def ranking_baselines(fr: pd.DataFrame, *, split_label: str) -> pd.DataFrame:\n",
    "    g = fr.groupby(\"system\", dropna=False)\n",
    "    mqm_mean = g[\"mqm\"].mean()\n",
    "    bleu_mean = g[\"bleu\"].mean()\n",
    "    chrf_mean = g[\"chrf\"].mean()\n",
    "    systems = mqm_mean.index.tolist()\n",
    "    K = len(systems)\n",
    "    if K < 3:\n",
    "        return pd.DataFrame([{\"split\": split_label, \"note\": \"need>=3 systems\"}])\n",
    "\n",
    "    human_good = -mqm_mean.reindex(systems).to_numpy(dtype=float)\n",
    "    bleu_v = bleu_mean.reindex(systems).to_numpy(dtype=float)\n",
    "    chrf_v = chrf_mean.reindex(systems).to_numpy(dtype=float)\n",
    "\n",
    "    rows_b = []\n",
    "    rng_b = np.random.default_rng(RANDOM_STATE)\n",
    "    rnd_taus = []\n",
    "    for _ in range(N_BASELINE_RANDOM):\n",
    "        noise = rng_b.standard_normal(K)\n",
    "        kt = kendalltau(human_good, noise, nan_policy=\"omit\")\n",
    "        rnd_taus.append(kt.statistic)\n",
    "    rows_b.append(\n",
    "        {\n",
    "            \"split\": split_label,\n",
    "            \"baseline\": \"random_noise_vs_human\",\n",
    "            \"kendall_tau_mean\": float(np.nanmean(rnd_taus)),\n",
    "            \"kendall_tau_std\": float(np.nanstd(rnd_taus)),\n",
    "            \"n_systems\": K,\n",
    "        }\n",
    "    )\n",
    "\n",
    "    for name, vec in [(\"mean_bleu_vs_human\", bleu_v), (\"mean_chrf_vs_human\", chrf_v)]:\n",
    "        kt = kendalltau(human_good, vec, nan_policy=\"omit\")\n",
    "        rows_b.append(\n",
    "            {\n",
    "                \"split\": split_label,\n",
    "                \"baseline\": name,\n",
    "                \"kendall_tau\": float(kt.statistic),\n",
    "                \"kendall_p\": float(kt.pvalue) if kt.pvalue is not None and not np.isnan(kt.pvalue) else np.nan,\n",
    "                \"n_systems\": K,\n",
    "            }\n",
    "        )\n",
    "\n",
    "    if \"comet\" in fr.columns and fr[\"comet\"].notna().any():\n",
    "        comet_mean = g[\"comet\"].mean().reindex(systems).to_numpy(dtype=float)\n",
    "        kt = kendalltau(human_good, comet_mean, nan_policy=\"omit\")\n",
    "        rows_b.append(\n",
    "            {\n",
    "                \"split\": split_label,\n",
    "                \"baseline\": \"mean_comet_vs_human\",\n",
    "                \"kendall_tau\": float(kt.statistic),\n",
    "                \"kendall_p\": float(kt.pvalue) if kt.pvalue is not None and not np.isnan(kt.pvalue) else np.nan,\n",
    "                \"n_systems\": K,\n",
    "            }\n",
    "        )\n",
    "\n",
    "    wins = pd.Series(0.0, index=systems)\n",
    "    perfect_rate = pd.Series(0.0, index=systems)\n",
    "    seg_groups = fr.groupby(\"seg_key\")\n",
    "    for _, part in seg_groups:\n",
    "        sub = part.dropna(subset=[\"mqm\", \"system\"])\n",
    "        if len(sub) < 2:\n",
    "            continue\n",
    "        best = sub[\"mqm\"].min()\n",
    "        winners = sub.loc[sub[\"mqm\"] == best, \"system\"]\n",
    "        w = 1.0 / len(winners)\n",
    "        for s in winners:\n",
    "            if s in wins.index:\n",
    "                wins[s] += w\n",
    "        for s in sub[\"system\"].unique():\n",
    "            if s in perfect_rate.index and (sub.loc[sub[\"system\"] == s, \"mqm\"] == 0).any():\n",
    "                perfect_rate[s] += 1\n",
    "    n_seg = fr[\"seg_key\"].nunique()\n",
    "    if n_seg:\n",
    "        perfect_rate = perfect_rate / n_seg\n",
    "\n",
    "    kt = kendalltau(human_good, wins.reindex(systems).to_numpy(dtype=float), nan_policy=\"omit\")\n",
    "    rows_b.append(\n",
    "        {\n",
    "            \"split\": split_label,\n",
    "            \"baseline\": \"win_frequency_vs_human\",\n",
    "            \"kendall_tau\": float(kt.statistic),\n",
    "            \"kendall_p\": float(kt.pvalue) if kt.pvalue is not None and not np.isnan(kt.pvalue) else np.nan,\n",
    "            \"n_systems\": K,\n",
    "        }\n",
    "    )\n",
    "\n",
    "    kt = kendalltau(\n",
    "        human_good,\n",
    "        perfect_rate.reindex(systems).to_numpy(dtype=float),\n",
    "        nan_policy=\"omit\",\n",
    "    )\n",
    "    rows_b.append(\n",
    "        {\n",
    "            \"split\": split_label,\n",
    "            \"baseline\": \"freq_zero_mqm_vs_human\",\n",
    "            \"kendall_tau\": float(kt.statistic),\n",
    "            \"kendall_p\": float(kt.pvalue) if kt.pvalue is not None and not np.isnan(kt.pvalue) else np.nan,\n",
    "            \"n_systems\": K,\n",
    "        }\n",
    "    )\n",
    "\n",
    "    return pd.DataFrame(rows_b)\n",
    "\n",
    "\n",
    "bl_dev = ranking_baselines(slice_frame(\"dev\", None), split_label=\"dev\")\n",
    "bl_test = ranking_baselines(slice_frame(\"test\", None), split_label=\"test\")\n",
    "print(\"baselines vs human system ranking (kendall tau). random should be near 0.\")\n",
    "display(pd.concat([bl_dev, bl_test], ignore_index=True))\n"
   ]
  },
