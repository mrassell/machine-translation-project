    "def system_level_table(frame: pd.DataFrame) -> pd.DataFrame:\n",
    "    g = frame.groupby(\"system\", dropna=False)\n",
    "    cols = [c for c in [\"bleu\", \"chrf\", \"comet\", \"mqm\", \"human_score\"] if c in frame.columns]\n",
    "    agg = g[cols].mean()\n",
    "    return agg.rename(columns={\"human_score\": \"neg_mean_mqm\"}).sort_values(\"mqm\")\n",
    "\n",
    "\n",
    "for split in [\"dev\", \"test\"]:\n",
    "    print(\"\\n--- system averages:\", split, \"---\")\n",
    "    st = system_level_table(slice_frame(split, None))\n",
    "    display(st)\n",
    "    sys_tbl = st.reset_index()\n",
    "    metric_cols = [c for c in METRICS if c in sys_tbl.columns]\n",
    "    print(\"spearman vs neg mean mqm (systems)\")\n",
    "    display(corr_table(sys_tbl, metric_cols, human_col=\"neg_mean_mqm\"))\n"
   ]
  },
